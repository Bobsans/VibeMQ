#: ../../index.rst:3 7e294a7199df4e9a9459c8690add70f2
msgid "VibeMQ — .NET Message Broker"
msgstr "VibeMQ — Месседж-брокер на .NET"

#: ../../index.rst:5 710bbc6268c7404eac0f9e8439299f5f
