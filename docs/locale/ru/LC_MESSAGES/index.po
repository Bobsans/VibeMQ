#: ../../index.rst:3 40de7c9cab8c4d5b85544ebd52d78a99
msgid "VibeMQ — .NET Message Broker"
msgstr "VibeMQ — Месседж-брокер на .NET"

#: ../../index.rst:5 7ee93635fa5b4f4c83f77d7e3f94b7cd
msgid ".NET Version"
