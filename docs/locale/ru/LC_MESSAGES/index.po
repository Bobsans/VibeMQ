#: ../../index.rst:121 02ef76acddf0453e9d9ceef8fcefd949
msgid "**Message Delivery Modes:**"
msgstr "**Режимы доставки сообщений:**"

#: ../../index.rst:123 94736c359732432faa0aa25c81004b5e
msgid "**Round-robin** — each message delivered to one subscriber (cyclically)"
msgstr ""
"**Round-robin** — каждое сообщение доставляется одному подписчику "
"(циклически)"

#: ../../index.rst:124 6df13e56f727465ab3f1281141d1b5b1
msgid ""
"**Fan-out with acknowledgment** — to all subscribers with delivery "
"guarantee"
msgstr "**Fan-out с подтверждением** — всем подписчикам с гарантией доставки"

#: ../../index.rst:125 87d95072bb5c481c945901a479ac6f27
msgid ""
"**Fan-out without acknowledgment** — to all subscribers without "
"confirmation"
msgstr "**Fan-out без подтверждения** — всем подписчикам без подтверждения"

#: ../../index.rst:126 168eee9ad1bd4554b9c63fc9800dce54
msgid "**Priority-based** — delivery by priority (Critical > High > Normal > Low)"
msgstr ""
"**Priority-based** — доставка по приоритету (Critical > High > Normal > "
"Low)"

#: ../../index.rst:128 e8b659153b0e45188511073d9ed10ea1
msgid "**Delivery Guarantees:**"
msgstr "**Гарантии доставки:**"

#: ../../index.rst:130 d296d69990ad430f87275ae54bf01ac0
msgid "Acknowledgments (ACK) from receivers"
msgstr "Подтверждения (ACK) от получателей"

#: ../../index.rst:131 d9f741c5133d426abad143727f8db996
msgid "Automatic retry attempts with exponential backoff"
msgstr "Автоматические повторные попытки с экспоненциальной задержкой"

#: ../../index.rst:132 e40c24bcdf284f04b120fa9366de9273
msgid "Dead Letter Queue for failed messages"
msgstr "Dead Letter Queue для неудачных сообщений"

#: ../../index.rst:133 38673c130af64b258d8a20541e62aa96
msgid "In-flight message tracking"
msgstr "Отслеживание неподтверждённых сообщений"

#: ../../index.rst:135 9a08fa6b3aaf434e8a4a568e465f4d08
msgid "**Reliability:**"
msgstr "**Надёжность:**"

#: ../../index.rst:137 84b9b5c3be6947e1ad31b12f7ed03645
msgid "Keep-alive (PING/PONG) for connection maintenance"
msgstr "Keep-alive (PING/PONG) для поддержания соединений"

#: ../../index.rst:138 c583899f5aca44f1aa28e9a0d85bc79b
msgid "Automatic reconnections on client side"
msgstr "Автоматические реконнекты на стороне клиента"

#: ../../index.rst:139 d1ff62f4857c4cbcbc7aaee61587f0e0
msgid "Graceful shutdown without message loss"
msgstr "Graceful shutdown без потери сообщений"

#: ../../index.rst:140 f8abece31600415bbda33663f88c5242
msgid "Health checks for orchestrators"
msgstr "Health checks для оркестраторов"

#: ../../index.rst:142 7024a6505e8d4eaca9487ba57e4396a1
msgid "**Persistence:**"
msgstr "**Персистентность:**"

#: ../../index.rst:144 a3d554a522f94e79a1cdd418a483ad2e
msgid "Pluggable storage providers (InMemory by default, SQLite available)"
msgstr "Подключаемые провайдеры хранилища (InMemory по умолчанию, доступен SQLite)"

#: ../../index.rst:145 66439931875247b78048fbeadad4ab80
msgid "Write-ahead logging — messages saved before delivery"
msgstr "Write-ahead — сообщения сохраняются до доставки"

#: ../../index.rst:146 a76827de940040889579d2ea20c766f7
msgid "Automatic recovery of queues and messages on restart"
msgstr "Автоматическое восстановление очередей и сообщений при перезапуске"

#: ../../index.rst:147 880c43fdd33447f4bed4095d889e91e1
msgid "Dead Letter Queue persistence"
msgstr "Персистентность Dead Letter Queue"

#: ../../index.rst:149 70024bf702074378a0fe1f68977902f8
msgid "**Security:**"
msgstr "**Безопасность:**"

#: ../../index.rst:151 9f2947fa03424869ab04ac4e1d04af2d
