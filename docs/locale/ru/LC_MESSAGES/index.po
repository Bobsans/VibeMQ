msgstr "Health checks для оркестраторов"

#: ../../index.rst:139 830d7de08ccf456baead450c39ed0c86
msgid "**Persistence:**"
msgstr "**Персистентность:**"

#: ../../index.rst:141 04d9baadf8ab49a79aa4390498000867
