msgid "Communication Protocol"
msgstr "Протокол связи"

#: ../../docs/protocol.rst:5 bf073e6afb024b90bd98cea564e7367d
msgid "This guide describes the VibeMQ message exchange protocol."
msgstr "Это руководство описывает протокол обмена сообщениями VibeMQ."

